# 世界杯预测系统环境变量配置
# 复制此文件为 .env 并填入你的 API keys

# 数据库配置（可选，默认使用 SQLite）
DATABASE_URL=sqlite+aiosqlite:///./data/worldcup.db

# 足球数据 API (football-data.org)
# 注册地址: https://www.football-data.org/client/register
# 免费版每月10次更新
FOOTBALL_DATA_API_KEY=

# API-Football (api-football.com)
# 注册地址: https://api-football.com/
# 免费版每天100次请求
API_FOOTBALL_KEY=

# 应用配置
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

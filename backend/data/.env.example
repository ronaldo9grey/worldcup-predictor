# 数据源配置示例
# 复制此文件为 .env 并填入实际值

# ========== 数据源配置 ==========
# 可选值: mock, balldontlie, worldcup26
# 推荐: worldcup26（免费、无需API Key、支持实时数据）
DATA_SOURCE=worldcup26

# ========== BALLDONTLIE API 配置 ==========
# 获取 API Key: https://app.balldontlie.io
BALLDONTLIE_API_KEY=your_api_key_here

# ========== 数据刷新配置 ==========
# 数据刷新间隔（秒），默认 300（5分钟）
# 实时数据建议设置为 60（1分钟）
DATA_REFRESH_INTERVAL=60

# ========== 缓存配置 ==========
# 缓存 TTL（秒），默认 300
CACHE_TTL=60

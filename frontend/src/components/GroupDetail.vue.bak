<template>
  <div class="groups-view">
    <div v-if="loading" class="loading"><div class="spinner"></div></div>
    <template v-else>
      <div class="groups-grid">
        <div v-for="gname in 'ABCDEFGHIJKL'.split('')" :key="gname" class="group-card" @click="toggleGroup(gname)">
          <div class="group-card-header">
            <span class="group-letter">{{ gname }}</span>
            <span class="group-label">组</span>
            <span class="expand-icon">{{ expanded === gname ? '▲' : '▼' }}</span>
          </div>
          <div v-if="groupCache[gname]" class="group-preview">
            <div v-for="t in groupCache[gname].standings.slice(0,4)" :key="t.code" class="preview-row">
              <span :class="['qualify-dot', t.position <= 2 ? 'dot-green' : t.position === 3 ? 'dot-yellow' : 'dot-gray']"></span>
              <span class="preview-name">{{ t.name_cn }}</span>
              <span class="preview-rank">#{{ t.rank }}</span>
              <span class="preview-pts">{{ t.predicted_points }}分</span>
            </div>
          </div>
          <div v-else class="preview-loading">
            <span class="loading-text">加载中...</span>
          </div>
        </div>
      </div>

      <div v-if="expanded && groupCache[expanded]" class="group-detail-panel">
        <div class="detail-header">
          <span class="detail-title">{{ expanded }}组详情</span>
          <button class="close-btn" @click="expanded = null">✕</button>
        </div>

        <div class="standings-visual">
          <div class="standings-header">
            <span class="standings-title">🏆 积分榜</span>
            <span class="standings-note">（基于预测结果，实际比赛积分）</span>
          </div>
          <div class="standings-bars">
            <div v-for="t in groupCache[expanded].standings" :key="t.code" 
                 :class="['standing-row', {'qualified': t.position <= 2}]">
              <span :class="['pos-badge', 'pos-' + t.position]">{{ t.position }}</span>
              <span class="team-flag">{{ getTeamFlag(t.code) }}</span>
              <span class="team-name">{{ t.name_cn }}</span>
              <span class="team-rank">FIFA #{{ t.rank }}</span>
              <span class="team-predicted-pts">
                <span class="pts-label">预测</span>
                <span class="pts-value">{{ t.predicted_points }}</span>
                <span class="pts-unit">分</span>
              </span>
              <span class="team-actual-pts">
                <span class="pts-label">实际</span>
                <span class="pts-value">{{ t.actual_points }}</span>
                <span class="pts-unit">分</span>
              </span>
              <span class="team-prob" v-if="qualificationData[expanded]">
                {{ getQualificationProb(t.code) }}%
              </span>
              <span class="team-prob" v-else>-</span>
            </div>
          </div>
        </div>

        <div class="detail-matches">
          <div class="detail-subtitle">赛程预测</div>
          <div v-for="(m, idx) in groupCache[expanded].matches" :key="idx" class="detail-match">
            <div class="dm-top">
              <div class="dm-teams">
                <span :class="{'dm-predicted': m.prediction === 'HOME_WIN' || m.prediction === '主胜'}">{{ m.home_name_cn }}</span>
                <span class="dm-vs">vs</span>
                <span :class="{'dm-predicted': m.prediction === 'AWAY_WIN' || m.prediction === '客胜'}">{{ m.away_name_cn }}</span>
              </div>
            </div>
            
            <!-- 预测概率条 -->
            <div class="dm-bar">
              <div class="dm-bar-h" :style="{width: m.home_win_prob*100+'%'}"></div>
              <div class="dm-bar-d" :style="{width: m.draw_prob*100+'%'}"></div>
              <div class="dm-bar-a" :style="{width: m.away_win_prob*100+'%'}"></div>
            </div>
            
            <!-- 三大数据因素（新增） -->
            <div class="dm-data-factors" v-if="m.odds_comparison || m.injury_comparison || m.sentiment_comparison">
              <!-- 赔率对比 -->
              <div class="factor-card" v-if="m.odds_comparison && m.odds_comparison.available">
                <div class="factor-header">
                  <span class="factor-icon">💰</span>
                  <span class="factor-title">市场赔率对比</span>
                </div>
                <div class="factor-source">数据来源：Bet365、威廉希尔、Pinnacle</div>
                <div class="odds-comparison">
                  <div class="odds-item">
                    <span class="odds-label">模型预测</span>
                    <span class="odds-value model">{{ (m.home_win_prob * 100).toFixed(0) }}%</span>
                  </div>
                  <div class="odds-item">
                    <span class="odds-label">市场共识</span>
                    <span class="odds-value market">{{ (m.odds_comparison.consensus.home_win * 100).toFixed(0) }}%</span>
                  </div>
                  <div class="odds-diff" :class="Math.abs(m.odds_comparison.model_vs_market.home_win_diff) > 0.05 ? 'highlight' : ''">
                    {{ m.odds_comparison.model_vs_market.home_win_diff > 0.05 ? '⚠️ 模型高估' : '✅ 基本一致' }}
                  </div>
                </div>
              </div>
              
              <!-- 伤病影响 -->
              <div class="factor-card" v-if="m.injury_comparison">
                <div class="factor-header">
                  <span class="factor-icon">🏥</span>
                  <span class="factor-title">伤病情况对比</span>
                </div>
                <div class="factor-source">数据来源：官方伤病报告 + 媒体报道</div>
                <div class="injury-summary">
                  <span class="injury-text" :class="m.injury_comparison.home_advantage > 0 ? 'advantage' : m.injury_comparison.home_advantage < 0 ? 'disadvantage' : ''">
                    {{ m.injury_comparison.summary || '双方健康' }}
                  </span>
                </div>
              </div>
              
              <!-- 情感分析 -->
              <div class="factor-card" v-if="m.sentiment_comparison">
                <div class="factor-header">
                  <span class="factor-icon">💬</span>
                  <span class="factor-title">球迷情感分析</span>
                </div>
                <div class="factor-source">数据来源：Twitter/X、微博、Reddit</div>
                <div class="sentiment-summary">
                  <span class="sentiment-text">{{ m.sentiment_comparison.summary || '信心相当' }}</span>
                </div>
              </div>
            </div>
            
            <div class="dm-bottom">
              <span class="dm-result">{{ getPredIcon(m.prediction) }} {{ getPredText(m.prediction) }}</span>
              <span :class="['dm-conf', 'conf-'+getConfLevel(m.confidence)]">{{ getConfText(m.confidence) }}</span>
              <button class="predict-btn" @click="showPredictDialog(expanded, idx, m)">🎯 我来预测</button>
              <button class="calc-btn" @click="showCalculation(expanded, idx, m)">🧠 贝叶斯预测分析</button>
              <button class="model-btn" @click="showModelPrediction(expanded, idx)">📊 三模型对比</button>
            </div>
          </div>
          
          <!-- 小组伤病汇总（新增） -->
          <div class="group-injury-summary" v-if="groupCache[expanded].injury_summary">
            <div class="summary-title">🏥 小组伤病情况</div>
            <div class="summary-grid">
              <div v-for="team in groupCache[expanded].injury_summary.teams" :key="team.code" class="summary-item">
                <span class="team-name">{{ team.name_cn }}</span>
                <span :class="['risk-badge', 'risk-' + team.risk_level]">{{ team.risk_label }}</span>
                <span class="injury-count" v-if="team.injury_count > 0">{{ team.injury_count }}人伤缺</span>
              </div>
            </div>
          </div>
          
          <!-- 小组情感汇总（新增） -->
          <div class="group-sentiment-summary" v-if="groupCache[expanded].sentiment_summary">
            <div class="summary-title">💬 小组情感分析</div>
            <div class="summary-grid">
              <div v-for="team in groupCache[expanded].sentiment_summary.teams" :key="team.code" class="summary-item">
                <span class="team-name">{{ team.name_cn }}</span>
                <div class="sentiment-metric">
                  <div class="metric-bar">
                    <div class="metric-fill" :style="{width: team.confidence_level * 100 + '%'}"></div>
                  </div>
                  <span class="metric-value">{{ (team.confidence_level * 100).toFixed(0) }}%</span>
                </div>
                <span class="pressure-badge" :class="'pressure-' + team.pressure_level">{{ getPressureText(team.pressure_level) }}</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </template>
    
    <MatchCalculation :visible="showCalc" :calculation="currentCalc" @close="showCalc = false" />
    <ModelPrediction :visible="showModelPred" :prediction="currentModelPred" @close="showModelPred = false" />
    
    <!-- 预测对话框 -->
    <div v-if="showPredict" class="predict-overlay" @click.self="showPredict = false">
      <div class="predict-dialog">
        <div class="predict-header">
          <h3>🎯 预测比赛</h3>
          <button class="close-btn" @click="showPredict = false">✕</button>
        </div>
        
        <div class="predict-body">
          <div class="predict-match-info">
            <div class="predict-teams">
              <span class="team-home">{{ currentMatch?.home_name_cn }}</span>
              <span class="vs">vs</span>
              <span class="team-away">{{ currentMatch?.away_name_cn }}</span>
            </div>
          </div>
          
          <!-- 未登录提示 -->
          <div v-if="!currentUser" class="need-login">
            <div class="login-icon">🎯</div>
            <p>请先在「我预测」页面设置昵称</p>
            <button class="goto-predict-btn" @click="gotoUserPredict">去设置昵称</button>
          </div>
          
          <!-- 已登录显示 -->
          <div v-else class="predict-form">
            <div class="user-info">
              <span class="user-label">当前身份：</span>
              <span class="user-name">{{ currentUser.nickname }}</span>
            </div>
            
            <div class="form-group">
              <label>预测结果</label>
              <div class="predict-options">
                <button 
                  :class="['option-btn', { active: predictResult === 'HOME_WIN' }]"
                  @click="predictResult = 'HOME_WIN'"
                >
                  🏠 主胜
                </button>
                <button 
                  :class="['option-btn', { active: predictResult === 'DRAW' }]"
                  @click="predictResult = 'DRAW'"
                >
                  🤝 平局
                </button>
                <button 
                  :class="['option-btn', { active: predictResult === 'AWAY_WIN' }]"
                  @click="predictResult = 'AWAY_WIN'"
                >
                  ✈️ 客胜
                </button>
              </div>
            </div>
            
            <div class="form-group">
              <label>信心程度</label>
              <div class="predict-options">
                <button 
                  :class="['conf-btn', 'conf-high', { active: predictConfidence === 'HIGH' }]"
                  @click="predictConfidence = 'HIGH'"
                >
                  高信心
                </button>
                <button 
                  :class="['conf-btn', 'conf-medium', { active: predictConfidence === 'MEDIUM' }]"
                  @click="predictConfidence = 'MEDIUM'"
                >
                  中信心
                </button>
                <button 
                  :class="['conf-btn', 'conf-low', { active: predictConfidence === 'LOW' }]"
                  @click="predictConfidence = 'LOW'"
                >
                  博冷门
                </button>
              </div>
            </div>
          </div>
          
          <div class="predict-stats" v-if="matchStats">
            <div class="stats-title">📊 网友预测分布</div>
            <div class="stats-bars">
              <div class="stat-item">
                <span class="stat-label">主胜</span>
                <div class="stat-bar">
                  <div class="stat-fill home" :style="{ width: matchStats.home_win_pct + '%' }"></div>
                </div>
                <span class="stat-value">{{ matchStats.home_win_pct }}%</span>
                <span class="stat-count">({{ matchStats.home_win_count }}人)</span>
              </div>
              <div class="stat-item">
                <span class="stat-label">平局</span>
                <div class="stat-bar">
                  <div class="stat-fill draw" :style="{ width: matchStats.draw_pct + '%' }"></div>
                </div>
                <span class="stat-value">{{ matchStats.draw_pct }}%</span>
                <span class="stat-count">({{ matchStats.draw_count }}人)</span>
              </div>
              <div class="stat-item">
                <span class="stat-label">客胜</span>
                <div class="stat-bar">
                  <div class="stat-fill away" :style="{ width: matchStats.away_win_pct + '%' }"></div>
                </div>
                <span class="stat-value">{{ matchStats.away_win_pct }}%</span>
                <span class="stat-count">({{ matchStats.away_win_count }}人)</span>
              </div>
            </div>
          </div>
        </div>
        
        <div class="predict-footer" v-if="currentUser">
          <button class="cancel-btn" @click="showPredict = false">取消</button>
          <button 
            class="submit-btn" 
            @click="submitPredict"
            :disabled="!predictResult || !predictConfidence"
          >
            提交预测
          </button>
        </div>
      </div>
    </div>
  </div>
</template>

<script setup>
import { ref, reactive, onMounted } from 'vue'
import MatchCalculation from './MatchCalculation.vue'
import ModelPrediction from './ModelPrediction.vue'

const loading = ref(false)
const expanded = ref(null)
const groupCache = reactive({})
const showCalc = ref(false)
const currentCalc = ref(null)
const showModelPred = ref(false)
const currentModelPred = ref(null)

// 预测相关
const showPredict = ref(false)
const currentMatch = ref(null)
const currentMatchGroup = ref(null)
const currentMatchIdx = ref(null)
const predictNickname = ref('')
const predictResult = ref(null)
const predictConfidence = ref(null)
const matchStats = ref(null)

const TEAM_FLAGS = {
  'ARG': '🇦🇷', 'BRA': '🇧🇷', 'FRA': '🇫🇷', 'ENG': '🏴󠁧󠁢󠁥󠁮󠁧󠁿', 'GER': '🇩🇪', 'ESP': '🇪🇸',
  'POR': '🇵🇹', 'NED': '🇳🇱', 'BEL': '🇧🇪', 'CRO': '🇭🇷', 'SUI': '🇨🇭', 'MEX': '🇲🇽', 'JPN': '🇯🇵',
  'KOR': '🇰🇷', 'AUS': '🇦🇺', 'USA': '🇺🇸', 'CAN': '🇨🇦', 'COL': '🇨🇴', 'URU': '🇺🇾', 'ECU': '🇪🇨',
  'SEN': '🇸🇳', 'MAR': '🇲🇦', 'EGY': '🇪🇬', 'NGA': '🇳🇬', 'CMR': '🇨🇲', 'GHA': '🇬🇭', 'TUN': '🇹🇳',
  'ZAF': '🇿🇦', 'CZE': '🇨🇿', 'POL': '🇵🇱', 'SWE': '🇸🇪', 'NOR': '🇳🇴', 'AUT': '🇦🇹', 'SRB': '🇷🇸',
  'IRN': '🇮🇷', 'SAU': '🇸🇦', 'QAT': '🇶🇦', 'UZB': '🇺🇿', 'JOR': '🇯🇴', 'IRQ': '🇮🇶'
}

function getTeamFlag(code) { return TEAM_FLAGS[code] || '⚽' }
function getBarWidth(points) { return Math.min(100, (points / 9) * 100) }
function getPredIcon(p) { 
  const iconMap = { HOME_WIN: '🏠', DRAW: '🤝', AWAY_WIN: '✈️', '主胜': '🏠', '平局': '🤝', '客胜': '✈️' }
  return iconMap[p] || '' 
}
function getPredText(p) { 
  const textMap = { HOME_WIN: '主胜', DRAW: '平', AWAY_WIN: '客胜', '主胜': '主胜', '平局': '平', '客胜': '客胜' }
  return textMap[p] || p || '' 
}
function getConfLevel(c) {
  const levelMap = { HIGH: 'high', MEDIUM: 'medium', LOW: 'low', '高': 'high', '中': 'medium', '低': 'low' }
  return levelMap[c] || 'medium'
}
function getConfText(c) {
  const textMap = { HIGH: '高', MEDIUM: '中', LOW: '低', '高': '高', '中': '中', '低': '低' }
  return textMap[c] || c || '中'
}

function getPressureText(p) {
  const textMap = { extreme: '极高压力', high: '高压', moderate: '适中', low: '低压' }
  return textMap[p] || p || '适中'
}

const qualificationData = ref({})

function loadQualificationProb(g) {
  // 异步加载，不阻塞
  if (qualificationData.value[g]) return
  
  fetch(`/worldcup/api/groups/${g}/qualification`)
    .then(resp => resp.json())
    .then(data => {
      qualificationData.value[g] = data
    })
    .catch(e => console.error('加载出线概率失败:', e))
}

function getQualificationProb(code) {
  const g = expanded.value
  if (!qualificationData.value[g]) return '-'
  const data = qualificationData.value[g]?.qualification_probability || []
  const team = data.find(t => t.code === code)
  return team ? team.qualification_prob : '-'
}

async function loadGroup(g) {
  if (groupCache[g]) return
  loading.value = true
  try {
    const resp = await fetch(`/worldcup/api/groups/${g}`)
    groupCache[g] = await resp.json()
  } catch(e) { console.error(e) }
  loading.value = false
}


async function toggleGroup(g) {
  if (expanded.value === g) { expanded.value = null; return }
  
  // 确保数据已加载
  if (!groupCache[g]) {
    await loadGroup(g)
  }
  
  expanded.value = g
  
  // 展开时异步加载出线概率（不阻塞）
  loadQualificationProb(g)
}


async function showCalculation(group, idx, match) {
  try {
    const resp = await fetch(`/worldcup/api/calculation/match/${group}/${idx}`)
    currentCalc.value = await resp.json()
    showCalc.value = true
  } catch (e) { console.error(e) }
}

async function showModelPrediction(group, idx) {
  try {
    const resp = await fetch(`/worldcup/api/models/predict/group/${group}/${idx}`)
    currentModelPred.value = await resp.json()
    showModelPred.value = true
  } catch (e) { console.error(e) }
}

async function showPredictDialog(group, idx, match) {
  currentMatchGroup.value = group
  currentMatchIdx.value = idx
  currentMatch.value = match
  showPredict.value = true
  
  // 加载预测统计
  try {
    const resp = await fetch(`/worldcup/api/user/prediction-stats/${group}/${idx}`)
    matchStats.value = await resp.json()
  } catch (e) {
    matchStats.value = null
  }
}

async function submitPredict() {
  if (!predictNickname.value || !predictResult.value || !predictConfidence.value) {
    return
  }
  
  try {
    const resp = await fetch('/worldcup/api/user/predict-simple', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        nickname: predictNickname.value,
        group: currentMatchGroup.value,
        match_idx: currentMatchIdx.value,
        prediction: predictResult.value,
        confidence: predictConfidence.value,
        home_code: currentMatch.value.home,
        away_code: currentMatch.value.away
      })
    })
    
    const data = await resp.json()
    
    if (data.success) {
      alert(`🎉 预测提交成功！\n\n${data.message}`)
      showPredict.value = false
      predictResult.value = null
      predictConfidence.value = null
      // 刷新统计
      const statsResp = await fetch(`/worldcup/api/user/prediction-stats/${currentMatchGroup.value}/${currentMatchIdx.value}`)
      matchStats.value = await statsResp.json()
    } else {
      alert('预测失败: ' + (data.error || '未知错误'))
    }
  } catch (e) {
    console.error('提交预测失败', e)
    alert('提交失败，请重试')
  }
}

// 页面加载时并发预加载所有小组数据
onMounted(async () => {
  const groups = 'ABCDEFGHIJKL'.split('')
  
  // 并发加载所有小组（不阻塞页面渲染）
  // 使用 Promise.all 并发，而非串行
  Promise.all(groups.map(g => loadGroup(g)))
    .then(() => console.log('✅ 所有小组数据已加载'))
    .catch(e => console.error('加载失败:', e))
})
</script>

<style scoped>
.groups-grid { display:grid; grid-template-columns:repeat(4, 1fr); gap:12px; margin-bottom:18px; }
.group-card { background:white; border-radius:10px; padding:14px; cursor:pointer; transition:all 0.2s; }
.group-card:hover { box-shadow:0 3px 12px rgba(0,0,0,0.12); }
.group-card-header { display:flex; align-items:baseline; margin-bottom:10px; }
.group-letter { font-size:1.5rem; font-weight:700; color:#1a472a; }
.group-label { font-size:1rem; color:#666; margin-left:4px; }
.expand-icon { margin-left:auto; font-size:0.9rem; color:#999; }
.preview-row { display:flex; align-items:center; gap:6px; padding:3px 0; font-size:1rem; }
.qualify-dot { width:8px; height:8px; border-radius:50%; }
.dot-green { background:#28a745; }
.dot-yellow { background:#ffc107; }
.dot-gray { background:#ccc; }
.team-predicted-pts, .team-actual-pts {
  display: inline-flex;
  align-items: baseline;
  gap: 3px;
  padding: 0 6px;
}
.pts-label {
  font-size: 0.85rem;
  color: #999;
  margin-right: 3px;
}
.team-predicted-pts .pts-value {
  font-weight: 700;
  color: #1a472a;
  font-size: 1.1rem;
}
.team-actual-pts .pts-value {
  font-weight: 700;
  color: #666;
  font-size: 1.1rem;
}
.pts-unit {
  font-size: 0.85rem;
  color: #666;
}
.preview-loading { padding:14px 0; text-align:center; }
.loading-text { font-size:1rem; color:#1a472a; opacity:0.6; }

.group-detail-panel { background:white; border-radius:12px; padding:18px; }
.detail-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:14px; }
.detail-title { font-weight:700; font-size:1.3rem; color:#1a472a; }
.close-btn { background:none; border:none; font-size:1.3rem; cursor:pointer; color:#999; }

.standings-visual { margin-bottom:20px; }
.standings-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:14px; }
.standings-title { font-weight:700; font-size:1.2rem; color:#1a472a; }
.simulate-btn { padding:6px 14px; background:#667eea; color:white; border:none; border-radius:8px; font-size:1rem; cursor:pointer; }
.standings-bars { display:flex; flex-direction:column; gap:8px; }
.standing-row { display:flex; align-items:center; gap:10px; padding:8px 10px; background:#f8f9fa; border-radius:8px; }
.standing-row.qualified { background:#e8f5e9; border-left:4px solid #28a745; }
